# Copy this file to .env and adjust values per environment.
# Discrete connection fields are used (rather than a single DATABASE_URL)
# so that special characters in the password never need URL-encoding.

PGHOST=localhost
PGPORT=<port>
PGUSER=<username>
PGPASSWORD=<password>
PGDATABASE=<database_name>

# JWT signing secret for the local auth provider. Use a long random string.
JWT_SECRET=<jwt_secret>
JWT_EXPIRES_IN=8h

# Bootstrap credentials for the Super Admin account, auto-created on server
# start when no Super Admin user exists yet (e.g. a fresh/empty database).
SUPER_ADMIN_USERNAME=<super_admin_username>
SUPER_ADMIN_PASSWORD=<super_admin_password>
SUPER_ADMIN_FIRST_NAME=<super_admin_first_name>
SUPER_ADMIN_LAST_NAME=<super_admin_last_name>
