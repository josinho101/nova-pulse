# Copy this file to .env and adjust values per environment.
# Discrete connection fields are used (rather than a single DATABASE_URL)
# so that special characters in the password never need URL-encoding.

PGHOST=localhost
PGPORT=<port>
PGUSER=<username>
PGPASSWORD=<password>
PGDATABASE=<database_name>

# JWT signing secret for the local auth provider. Use a long random string.
JWT_SECRET=<jwt_secret>
JWT_EXPIRES_IN=8h
